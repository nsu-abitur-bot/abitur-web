    "/api/v1/faq": {
      "get": {
        "tags": [
          "FAQ Management"
        ],
        "summary": "Получить все FAQ",
        "description": "Возвращает список всех вопросов и ответов FAQ, которые использует бот.",
        "operationId": "get_all_faqs_api_v1_faq_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FaqListResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "FAQ Management"
        ],
        "summary": "Создать FAQ",
        "description": "Создает новый вопрос FAQ и автоматически применяет для новых запросов к боту.",
        "operationId": "create_faq_api_v1_faq_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FaqItem"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FaqItem"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/faq/upload": {
      "post": {
        "tags": [
          "FAQ Management"
        ],
        "summary": "Загрузить FAQ из CSV",
        "description": "Загружает вопросы и ответы FAQ из CSV-файла.\nОжидается CSV файл с колонками \"Вопросы\" и \"Ответы\".\nПустая строка означает, что начинается новый вопрос.\nПервый вопрос в блоке становится основным, остальные - альтернативными формулировками (aliases).",
        "operationId": "upload_faq_csv_api_v1_faq_upload_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_upload_faq_csv_api_v1_faq_upload_post"
