{
  "openapi": "3.1.0",
  "info": {
    "title": "Abitur API",
    "version": "0.1.0"
  },
  "paths": {
    "/api/v1/faq": {
      "get": {
        "tags": [
          "FAQ Management"
        ],
        "summary": "Получить все FAQ",
        "description": "Возвращает список всех вопросов и ответов FAQ, которые использует бот.",
        "operationId": "get_all_faqs_api_v1_faq_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FaqListResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "FAQ Management"
        ],
        "summary": "Создать FAQ",
        "description": "Создает новый вопрос FAQ и автоматически применяет для новых запросов к боту.",
        "operationId": "create_faq_api_v1_faq_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FaqItem"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FaqItem"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/faq/{index}": {
      "put": {
        "tags": [
          "FAQ Management"
        ],
        "summary": "Обновить FAQ по индексу",
        "description": "Обновляет существующий FAQ элемент по его позиции (индексу) в списке.",
        "operationId": "update_faq_api_v1_faq__index__put",
        "parameters": [
          {
            "name": "index",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Index"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FaqItem"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FaqItem"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "FAQ Management"
        ],
        "summary": "Удалить FAQ по индексу",
        "description": "Удаляет существующий FAQ элемент по его позиции (индексу) в списке.",
        "operationId": "delete_faq_api_v1_faq__index__delete",
        "parameters": [
          {
            "name": "index",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Index"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Successful Response"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/rag/upload": {
      "post": {
        "tags": [
          "RAG Management"
        ],
        "summary": "Загрузить документы в RAG",
        "operationId": "upload_documents_to_rag_api_v1_rag_upload_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_upload_documents_to_rag_api_v1_rag_upload_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RagUploadResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/rag/parse": {
      "post": {
        "tags": [
          "RAG Management"
        ],
        "summary": "Спарсить страницу для RAG",
        "description": "Парсит страницу, очищает текст через LLM и находит документы.",
        "operationId": "parse_page_for_rag_api_v1_rag_parse_post",
        "parameters": [
          {
            "name": "url",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uri",
              "minLength": 1,
              "maxLength": 2083,
              "description": "URL страницы",
              "title": "Url"
            },
            "description": "URL страницы"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ParsedPageResult"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/rag/confirm": {
      "post": {
        "tags": [
          "RAG Management"
        ],
        "summary": "Подтвердить загрузку в RAG",
        "description": "Загружает отредактированный текст и выбранные документы в RAG.",
        "operationId": "confirm_rag_upload_api_v1_rag_confirm_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ConfirmUploadRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {

                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/rag/docs": {
      "get": {
        "tags": [
          "RAG Management"
        ],
        "summary": "Список документов в RAG",
        "description": "Возвращает список всех загруженных в RAG документов.",
        "operationId": "list_rag_documents_api_v1_rag_docs_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RagDocumentListResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/rag/docs/{doc_id}": {
      "delete": {
        "tags": [
          "RAG Management"
        ],
        "summary": "Удалить документ из RAG",
        "description": "Удаляет документ из RAG по его ID (URL или имени файла).",
        "operationId": "delete_rag_document_api_v1_rag_docs__doc_id__delete",
        "parameters": [
          {
            "name": "doc_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Doc Id"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Successful Response"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/users/count-stats": {
      "get": {
        "summary": "Get Users Count Stats",
        "operationId": "get_users_count_stats_api_v1_users_count_stats_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserCountStatsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/messages": {
      "get": {
        "summary": "Get Messages",
        "description": "Возвращает список сообщений и ответов бота.",
        "operationId": "get_messages_api_v1_messages_get",
        "parameters": [
          {
            "name": "user_id",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Фильтр по user_id",
              "title": "User Id"
            },
            "description": "Фильтр по user_id"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 500,
              "minimum": 1,
              "description": "Количество записей",
              "default": 50,
              "title": "Limit"
            },
            "description": "Количество записей"
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0,
              "description": "Смещение",
              "default": 0,
              "title": "Offset"
            },
            "description": "Смещение"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MessageResponse"
                  },
                  "title": "Response Get Messages Api V1 Messages Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Body_upload_documents_to_rag_api_v1_rag_upload_post": {
        "properties": {
          "files": {
            "items": {
              "type": "string",
              "contentMediaType": "application/octet-stream"
            },
            "type": "array",
            "title": "Files",
            "description": "Файлы для индексации в RAG"
          }
        },
        "type": "object",
        "required": [
          "files"
        ],
        "title": "Body_upload_documents_to_rag_api_v1_rag_upload_post"
      },
      "ConfirmUploadRequest": {
        "properties": {
          "text": {
            "type": "string",
            "title": "Text",
            "description": "Отредактированный текст страницы"
          },
          "documents": {
            "items": {
              "$ref": "#/components/schemas/ParsedDocument"
            },
            "type": "array",
            "title": "Documents",
            "description": "Финальный список файлов для загрузки"
          }
        },
        "type": "object",
        "required": [
          "text",
          "documents"
        ],
        "title": "ConfirmUploadRequest"
      },
      "FaqItem": {
        "properties": {
          "question": {
            "type": "string",
            "title": "Question",
            "description": "Основной вопрос"
          },
          "aliases": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Aliases",
            "description": "Альтернативные формулировки (синонимы) вопроса"
          },
          "answer": {
            "type": "string",
            "title": "Answer",
            "description": "Текст ответа"
          }
        },
        "type": "object",
        "required": [
          "question",
          "answer"
        ],
        "title": "FaqItem",
        "description": "Схема для отдельного элемента FAQ."
      },
      "FaqListResponse": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/FaqItem"
            },
            "type": "array",
            "title": "Items",
            "description": "Список вопросов-ответов"
          }
        },
        "type": "object",
        "required": [
          "items"
        ],
        "title": "FaqListResponse",
        "description": "Схема ответа для списка FAQ-вопросов."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "MessageResponse": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "user_id": {
            "type": "integer",
            "title": "User Id"
          },
          "username": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Username"
          },
          "session_id": {
            "type": "string",
            "title": "Session Id"
          },
          "user_text": {
            "type": "string",
            "title": "User Text"
          },
          "bot_response": {
            "type": "string",
            "title": "Bot Response"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          }
        },
        "type": "object",
        "required": [
          "id",
          "user_id",
          "session_id",
          "user_text",
          "bot_response",
          "created_at"
        ],
        "title": "MessageResponse"
      },
      "ParsedDocument": {
        "properties": {
          "title": {
            "type": "string",
            "title": "Title",
            "description": "Название документа"
          },
          "url": {
            "type": "string",
            "title": "Url",
            "description": "URL для скачивания/ссылки на документ"
          }
        },
        "type": "object",
        "required": [
          "title",
          "url"
        ],
        "title": "ParsedDocument"
      },
      "ParsedPageResult": {
        "properties": {
          "text": {
            "type": "string",
            "title": "Text",
            "description": "Сырой или предобработанный текст страницы"
          },
          "documents": {
            "items": {
              "$ref": "#/components/schemas/ParsedDocument"
            },
            "type": "array",
            "title": "Documents",
            "description": "Список найденных PDF-документов"
          }
        },
        "type": "object",
        "required": [
          "text",
          "documents"
        ],
        "title": "ParsedPageResult"
      },
      "RagDocument": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id",
            "description": "Идентификатор документа (обычно URL или имя файла)"
          },
          "status": {
            "type": "string",
            "title": "Status",
            "description": "Статус обработки"
          },
          "content_summary": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Content Summary",
            "description": "Краткое содержание"
          },
          "content_length": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Content Length",
            "description": "Длина контента"
          },
          "created_at": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Created At",
            "description": "Дата создания"
          }
        },
        "type": "object",
        "required": [
          "id",
          "status"
        ],
        "title": "RagDocument"
      },
      "RagDocumentListResponse": {
        "properties": {
          "documents": {
            "items": {
              "$ref": "#/components/schemas/RagDocument"
            },
            "type": "array",
            "title": "Documents",
            "description": "Список документов в RAG"
          }
        },
        "type": "object",
        "required": [
          "documents"
        ],
        "title": "RagDocumentListResponse"
      },
      "RagUploadResponse": {
        "properties": {
          "accepted_formats": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Accepted Formats",
            "description": "Поддерживаемые расширения файлов"
          },
          "indexed_count": {
            "type": "integer",
            "title": "Indexed Count",
            "description": "Количество успешно проиндексированных файлов"
          },
          "skipped_count": {
            "type": "integer",
            "title": "Skipped Count",
            "description": "Количество пропущенных файлов"
          },
          "results": {
            "items": {
              "$ref": "#/components/schemas/UploadedDocumentResult"
            },
            "type": "array",
            "title": "Results",
            "description": "Результаты обработки по каждому загруженному файлу"
          }
        },
        "type": "object",
        "required": [
          "accepted_formats",
          "indexed_count",
          "skipped_count",
          "results"
        ],
        "title": "RagUploadResponse"
      },
      "UploadedDocumentResult": {
        "properties": {
          "filename": {
            "type": "string",
            "title": "Filename",
            "description": "Имя загруженного файла"
          },
          "status": {
            "type": "string",
            "title": "Status",
            "description": "Статус обработки: indexed или skipped"
          },
          "message": {
            "type": "string",
            "title": "Message",
            "description": "Подробности результата обработки"
          },
          "chars": {
            "type": "integer",
            "title": "Chars",
            "description": "Количество символов, отправленных в RAG",
            "default": 0
          }
        },
        "type": "object",
        "required": [
          "filename",
          "status",
          "message"
        ],
        "title": "UploadedDocumentResult"
      },
      "UserCountStatsResponse": {
        "properties": {
          "day": {
            "type": "integer",
            "title": "Day"
          },
          "week": {
            "type": "integer",
            "title": "Week"
          },
          "month": {
            "type": "integer",
            "title": "Month"
          },
          "year": {
            "type": "integer",
            "title": "Year"
          },
          "all_time": {
            "type": "integer",
            "title": "All Time"
          }
        },
        "type": "object",
        "required": [
          "day",
          "week",
          "month",
          "year",
          "all_time"
        ],
        "title": "UserCountStatsResponse"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}
