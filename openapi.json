        "description": "Возвращает список сообщений и ответов бота.",
        "operationId": "get_messages_api_v1_messages_get",
        "parameters": [
          {
            "name": "user_id",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Фильтр по user_id",
              "title": "User Id"
            },
            "description": "Фильтр по user_id"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 500,
              "minimum": 1,
              "description": "Количество записей",
              "default": 50,
              "title": "Limit"
            },
            "description": "Количество записей"
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0,
              "description": "Смещение",
              "default": 0,
              "title": "Offset"
            },
            "description": "Смещение"
          }
